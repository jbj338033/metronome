{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@metronome/types": ["../../packages/types/dist"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../../packages/types" }]
}
